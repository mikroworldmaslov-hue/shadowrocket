# --- GitHub ---
*.github.com = server:system
github.com = server:system
*.githubusercontent.com = server:system
*.githubassets.com = server:system
*.github.io = server:system

# --- VK целиком, включая рекламу/аналитику ---
vk.com = server:system
*.vk.com = server:system
vk.ru = server:system
*.vk.ru = server:system
*.userapi.com = server:system
*.vkuserphoto.ru = server:system
*.vkuser.net = server:system
